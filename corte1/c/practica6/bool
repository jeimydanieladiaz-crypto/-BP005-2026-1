#include <stdio.h>

#include <stdbool.h>

  int main () {

      int time;

      printf("Ingrese la hora en formato militar: ");
      scanf("%d", &time);

          bool isMorning = time < 12;
          bool isDay = time < 18;

          if (isMorning) {
            printf("Good morning.");

          } else if (isDay) {
            printf("Good day.");
   
          } else {
            printf("Good evening.");

          }

return 0;

} 
