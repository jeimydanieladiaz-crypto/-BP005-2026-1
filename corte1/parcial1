#include <stdio.h>
#include <stdbool.h>

int main() {

    printf("Sistema de analisis academico\n\n");

    int codigo, edad;
    char nombre[50];
    float nota1, nota2, nota3, promedio;
    double matricula;

    // Cambiado de bool a int
    int matriculaActiva, documento, induccion, monitor;

    printf("Ingrese el codigo del estudiante: ");
    scanf("%d", &codigo);

    printf("Ingrese el nombre del estudiante: ");
    scanf("%s", nombre);

    printf("Ingrese la edad: ");
    scanf("%d", &edad);

    printf("Ingrese nota 1: ");
    scanf("%f", &nota1);

    printf("Ingrese nota 2: ");
    scanf("%f", &nota2);

    printf("Ingrese nota 3: ");
    scanf("%f", &nota3);

    printf("Ingrese valor de matricula: ");
    scanf("%lf", &matricula);

    printf("Tiene matricula activa? (1=Si, 0=No): ");
    scanf("%d", &matriculaActiva);

    printf("Presento documento? (1=Si, 0=No): ");
    scanf("%d", &documento);

    printf("Aprobo induccion? (1=Si, 0=No): ");
    scanf("%d", &induccion);

    printf("Es monitor? (1=Si, 0=No): ");
    scanf("%d", &monitor);

    if (nota1 < 0 || nota1 > 5 || nota2 < 0 || nota2 > 5 || nota3 < 0 || nota3 > 5) {
        printf("\nERROR: Las notas deben estar entre 0.0 y 5.0\n");
        return 0;
    }

    promedio = (nota1 + nota2 + nota3) / 3;

    (codigo % 2 == 0) ? printf("\nEl codigo es par\n") : printf("\nEl codigo es impar\n");

    printf("\nDesempeno academico: ");
    if (promedio < 3.0) {
        printf("Reprobado");
    } else if (promedio < 4.0) {
        printf("Aprobado con desempeño bajo");
    } else if (promedio < 4.5) {
        printf("Aprobado con buen desempeño");
    } else {
        printf("Aprobado con excelente desempeño");
    }

    int acceso = matriculaActiva && documento && (induccion || monitor);

    if (acceso) {
        printf("\n\nPuede ingresar al laboratorio.");

        if (monitor) {
            printf("\nAcceso especial como monitor.");
        } else {
            printf("\nAcceso normal.");
        }

    } else {
        printf("\n\nNo puede ingresar al laboratorio.");
    }

    printf("\n\nResumen\n");
    printf("Codigo: %d\n", codigo);
    printf("Nombre: %s\n", nombre);
    printf("Edad: %d\n", edad);
    printf("Promedio: %.2f\n", promedio);
    printf("Matricula: %.2lf\n", matricula);

    return 0;
}  
